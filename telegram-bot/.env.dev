# Конфигурация для независимой разработки
# Используется при разработке бота отдельно от базы

# Telegram Bot Configuration
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
ADMIN_USER_ID=your_telegram_user_id

# Development Database URLs (для подключения к отдельным контейнерам)
DATABASE_URL=postgresql+asyncpg://bot_user:bot_password_2024@localhost:5432/telegram_bot
REDIS_URL=redis://:redis_password_2024@localhost:6379/0

# Или подключение через Docker network (если бот тоже в Docker)
# DATABASE_URL=postgresql+asyncpg://bot_user:bot_password_2024@telegram-bot-postgres:5432/telegram_bot
# REDIS_URL=redis://:redis_password_2024@telegram-bot-redis:6379/0

# Development Settings
LOG_LEVEL=DEBUG
LOG_FORMAT=text
MAX_LOG_SIZE=50MB
LOG_RETENTION=7d

# Development Security (более мягкие ограничения)
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_SEARCH=200/minute
RATE_LIMIT_ADMIN=1000/minute

# Development Features
ENABLE_DEBUG_COMMANDS=true
ENABLE_TEST_ENDPOINTS=true
AUTO_RELOAD=true
