# IT-Outsource System Environment Variables
# Скопируйте в .env и заполните реальными значениями

# Основные настройки
ENVIRONMENT=development
PROJECT_NAME=it-outsource-system

# База данных
POSTGRES_USER=ito_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ito_main

# Redis
REDIS_PASSWORD=your_redis_password_here

# NetBox
NETBOX_ADMIN_EMAIL=admin@yourcompany.com
NETBOX_ADMIN_PASSWORD=netbox_admin_password
NETBOX_SECRET_KEY=generate_50_char_secret_key_here
NETBOX_API_TOKEN=your_netbox_api_token

# Vaultwarden
VAULTWARDEN_DOMAIN=vault.yourcompany.com
VAULTWARDEN_ADMIN_TOKEN=generate_secure_admin_token

# BookStack
BOOKSTACK_DOMAIN=docs.yourcompany.com
BOOKSTACK_API_TOKEN=your_bookstack_api_token

# Email/SMTP
SMTP_HOST=smtp.gmail.com
SMTP_FROM=noreply@yourcompany.com
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Telegram Bot Configuration
TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_API_ID=your_api_id_from_my_telegram_org
TELEGRAM_API_HASH=your_api_hash_from_my_telegram_org
ADMIN_USER_IDS=123456789,987654321  # Telegram user IDs of admins (comma-separated)

# Database Configuration
DATABASE_URL=postgresql+asyncpg://bot_user:bot_password@localhost:5432/telegram_bot
REDIS_URL=redis://:redis_password@localhost:6379/0

# n8n Integration (for work journal module)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/work-journal
N8N_WEBHOOK_SECRET=your_webhook_secret_key

# Google Sheets Configuration (used by n8n)
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# Plane Integration
PLANE_CHAT_ID=-1001234567890  # ID чата для уведомлений Plane
PLANE_TOPIC_ID=123  # ID топика в групповом чате (опционально)
PLANE_WEBHOOK_SECRET=your_plane_webhook_secret_key

# API Integrations (optional)
VAULTWARDEN_URL=https://vault.yourcompany.com
OUTLINE_URL=https://docs.yourcompany.com
ZAMMAD_URL=https://support.yourcompany.com
ZAMMAD_TOKEN=your_zammad_api_token

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
MAX_LOG_SIZE=100MB
LOG_RETENTION=30d

# Bot Settings
RATE_LIMIT_DEFAULT=10/minute
RATE_LIMIT_SEARCH=30/minute
RATE_LIMIT_ADMIN=100/minute
SESSION_TIMEOUT=3600

# Домены (для продакшена)
MAIN_DOMAIN=yourcompany.com
NETBOX_DOMAIN=netbox.yourcompany.com
